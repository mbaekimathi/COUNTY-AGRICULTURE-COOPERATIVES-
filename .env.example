# Copy to .env and set values. Never commit .env.

# Required in production: long random string
FLASK_SECRET_KEY=change-this-to-a-long-random-string

# MySQL (local / VM). Omit if using DATABASE_URL.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=meru_cooperatives

# Optional: single URL from Railway, Render, Azure, etc. (overrides MYSQL_* when set)
# DATABASE_URL=mysql://user:password@host:3306/meru_cooperatives

# Behind nginx / a load balancer with HTTPS: trust X-Forwarded-* headers
# TRUST_PROXY_HEADERS=1

# HTTPS deployments: send secure cookies only
# SESSION_COOKIE_SECURE=1

# Upload body limit (MB)
# MAX_CONTENT_LENGTH_MB=25
